{
  "name": "@lanrenbang/chat-adapter-ilink",
  "version": "0.1.1",
  "description": "Weixin iLink bot adapter for Chat SDK",
  "ilink_appid": "bot",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "test": "vitest run --coverage",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "chat": "^4.31.0"
  },
  "dependencies": {
    "@chat-adapter/shared": "^4.31.0"
  },
  "optionalDependencies": {
    "silk-wasm": "^3.7.1"
  },
  "devDependencies": {
    "@chat-adapter/state-memory": "^4.31.0",
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^4.0.0",
    "chat": "^4.31.0",
    "tsup": "^8.3.0",
    "typescript": "^5.7.0",
    "vitest": "^4.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": ["chat-sdk", "chat-adapter", "weixin", "wechat", "ilink"],
  "license": "MIT"
}
